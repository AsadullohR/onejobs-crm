# ─── SERVER (.env in /server) ─────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/onejobs

# JWT secret - CHANGE THIS in production!
JWT_SECRET=onejobs-super-secret-key-change-me

# Webhook API key for Make.com/Zapier
WEBHOOK_KEY=your-webhook-key-here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Port
PORT=3001

# Node environment
NODE_ENV=development

# ─── PRODUCTION (Render.com / Railway) ────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# NODE_ENV=production
# FRONTEND_URL=https://your-app.vercel.app

# ─── CLIENT (.env in /client) ─────────────────────────────────────────────────
# VITE_API_URL=http://localhost:3001
# VITE_API_URL=https://your-api.onrender.com  (production)
